# Copy this file to .streamlit/secrets.toml for local runs
# (Streamlit Cloud: paste the same keys into Settings -> Secrets instead)
# NEVER commit the real secrets.toml file to GitHub.

UPSTOX_API_KEY = "your_upstox_api_key"
UPSTOX_API_SECRET = "your_upstox_api_secret"
UPSTOX_REDIRECT_URI = "https://your-app-name.streamlit.app"
